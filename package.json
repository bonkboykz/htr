{
  "name": "htr",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "start": "pnpm db:migrate && pnpm db:seed && pnpm --filter @htr/api start",
    "db:migrate": "pnpm --filter @htr/engine db:migrate",
    "db:seed": "pnpm --filter @htr/engine db:seed"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "packageManager": "pnpm@9.15.0"
}
